[Desktop Entry]
Type=Application
Name=Omikuji
GenericName=Game Launcher
Exec=omikuji %f
Icon=io.github.reakjra.omikuji
StartupWMClass=omikuji
Categories=Game;PackageManager;
Keywords=gaming;launcher;
MimeType=application/x-ms-dos-executable;application/x-msdownload;application/vnd.microsoft.portable-executable;
StartupNotify=true
Terminal=false
Comment=Qt/QML based wine apps launcher for Linux
